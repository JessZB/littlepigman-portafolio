---
import { Image } from 'astro:assets';
interface Props {
  project: {
    id: string;
    title: string;
    category: string;
    thumbnail: string;
  };
}

const { project } = Astro.props;
---

<div class="project-card" onclick={`openProject('${project.id}')`}>
  {project.thumbnail ? (
    <Image src={project.thumbnail} alt={project.title} width={400} height={225} class="w-full h-full object-cover" />
  ) : (
    <div class="w-full h-full bg-gray-900 flex items-center justify-center text-gray-700">
       <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
    </div>
  )}
  <div class="project-title-bar">
    <span class="truncate pr-2">{project.title}</span>
    <span class="text-[var(--color-accent)] text-xs sm:text-sm border border-[var(--color-accent)] px-1 whitespace-nowrap hidden min-[350px]:block">
      {project.category}
    </span>
  </div>
</div>
