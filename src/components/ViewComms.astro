---
import Panel from './Panel.astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../i18n/utils';

const { lang } = Astro.props;
const t = useTranslations(lang);

let profile;
try {
  const profileModule = await import(`../data/profile.${lang}.json`);
  profile = profileModule.default;
} catch (e) {
  profile = { socials: [], contact: { title: t('comms.title'), description: t('comms.label1') } };
}

const socialsData = profile.socials || [];
---

<section id="view-comms" class="view-hidden flex-1 flex flex-col h-full overflow-y-auto pr-1 sm:pr-2">
  <Panel className="p-3 sm:p-4 h-full flex flex-col relative min-h-[500px]">
    <h2 class="text-2xl sm:text-3xl text-white uppercase border-b-2 border-[var(--color-danger)] pb-2 mb-4 sm:mb-6 shrink-0">
      {profile.contact.title || t('comms.title')}
    </h2>
    
    <div class="flex flex-col lg:flex-row gap-6 sm:gap-8 flex-1">
      <div class="flex-1 flex flex-col gap-3 sm:gap-4">
        <p class="text-[var(--color-text-muted)] text-sm sm:text-base">
          {profile.contact.description || t('comms.label1')}
        </p>
        <input type="text" placeholder={t('comms.placeholder1')} class="bg-black border-2 border-[var(--color-panel-border)] text-white p-2 focus:outline-none focus:border-[var(--color-accent)] font-['VT323'] text-lg sm:text-xl w-full" />
        <textarea placeholder={t('comms.placeholder2')} class="bg-black border-2 border-[var(--color-panel-border)] text-white p-2 flex-1 min-h-[120px] resize-none focus:outline-none focus:border-[var(--color-accent)] font-['VT323'] text-lg sm:text-xl w-full"></textarea>
        <button class="bg-[var(--color-panel-bg)] border-2 border-[var(--color-panel-border)] text-white p-2 sm:p-3 hover:bg-[var(--color-panel-border)] hover:text-black transition-colors font-bold uppercase cursor-pointer text-sm sm:text-base w-full">
          {t('comms.submit')}
        </button>
      </div>

      <div class="w-full lg:w-1/3 flex flex-col gap-3 sm:gap-4 border-t-2 lg:border-t-0 lg:border-l-2 border-[var(--color-danger)] pt-4 lg:pt-0 lg:pl-4">
        <h3 class="text-[var(--color-text-muted)] text-lg border-b border-[var(--color-highlight)] pb-1 mb-2">{t('comms.socials')}</h3>
        {socialsData.map((social: any) => (
          <a href={social.link} target={social.link === '#' ? '_self' : '_blank'} class="text-white hover:text-[var(--color-accent)] text-lg mb-2 flex items-center gap-3 group">
            {social.icon && !social.icon.includes('undefined') ? (
              <Image src={social.icon as any} alt="icon" width={32} height={32} class="w-8 h-8 pixelated group-hover:scale-110 transition-transform" />
            ) : (
              <div class="w-8 h-8 border border-gray-600 flex items-center justify-center text-gray-700">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              </div>
            )}
            <span>{social.name}</span>
          </a>
        ))}
      </div>
    </div>
  </Panel>
</section>
