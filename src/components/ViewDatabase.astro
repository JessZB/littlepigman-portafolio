---
import Panel from './Panel.astro';
import ProjectCard from './ProjectCard.astro';
import { useTranslations } from '../i18n/utils';

const { lang, worksData } = Astro.props;
const t = useTranslations(lang);
---

<section id="view-database" class="view-hidden flex-1 flex flex-col h-full relative overflow-hidden">
  <Panel className="flex-1 flex flex-col h-full p-3 sm:p-4 relative overflow-hidden">
    <!-- ESTADO A: Lista de Proyectos -->
    <div id="project-list-view" class="flex flex-col h-full">
      <div class="flex justify-between items-center mb-3 sm:mb-4 border-b-2 border-[var(--color-panel-border)] pb-2 shrink-0">
        <h2 class="text-2xl sm:text-3xl text-white uppercase">{t('db.title')}</h2>
        <div class="text-[var(--color-panel-border)] text-xs sm:text-sm animate-pulse hidden sm:block">
          {t('db.status')}
        </div>
      </div>
      <div class="flex-1 overflow-y-auto pr-1 sm:pr-2">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4" id="projects-grid">
          {worksData.map((project: any) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </div>
    </div>

    <!-- ESTADO B: Detalle del Proyecto -->
    <div id="project-detail-view" class="view-hidden absolute inset-0 bg-[var(--color-panel-bg)] p-3 sm:p-4 flex flex-col h-full z-20 overflow-y-auto">
      <div class="flex justify-between items-center mb-3 sm:mb-4 pb-2 border-b-2 border-[var(--color-panel-border)] shrink-0 sticky top-0 bg-[var(--color-panel-bg)] z-30">
        <button onclick="closeProject()" class="bg-black border border-[var(--color-accent)] text-[var(--color-accent)] px-2 sm:px-3 py-1 hover:bg-[var(--color-accent)] hover:text-black transition-colors text-sm sm:text-base cursor-pointer truncate max-w-[70%]">
          {t('proj.goBack')}
        </button>
        <div class="text-[var(--color-text-muted)] text-xs sm:text-sm">{t('proj.loading')}</div>
      </div>
      <div id="project-content-area" class="flex flex-col gap-4 sm:gap-6 pb-4">
        <!-- Inyectado vía JS Cliente -->
      </div>
    </div>
  </Panel>
</section>
