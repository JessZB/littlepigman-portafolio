---
import Panel from './Panel.astro';
import StatBar from './StatBar.astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../i18n/utils';

const { lang } = Astro.props;
const aboutDataModule = await import(`../data/about.${lang}.json`);
const aboutData = aboutDataModule.default;
const t = useTranslations(lang);
---

<section id="view-profile" class="flex-1 flex flex-col gap-2 sm:gap-4 h-full overflow-y-auto pr-1 sm:pr-2">
  <Panel className="p-3 sm:p-4 flex flex-col sm:flex-row gap-4 sm:gap-6 items-center sm:items-start shrink-0 text-center sm:text-left">
    <div class="w-24 h-24 sm:w-48 sm:h-48 border-4 border-[var(--color-panel-border)] bg-black relative shrink-0">
      <Image src={aboutData.avatar} alt="Avatar" width={192} height={192} class="w-full h-full object-cover" loading="eager" />
      <div class="absolute bottom-0 w-full bg-[var(--color-panel-border)] text-black text-center font-bold text-xs sm:text-sm">
        Lv. {aboutData.level}
      </div>
    </div>
    <div class="flex-1 w-full">
      <div class="flex flex-col sm:flex-row justify-between items-center sm:items-end border-b-2 border-gray-600 pb-2 mb-2 gap-2">
        <div>
          <div class="text-xs sm:text-sm text-[var(--color-panel-border)]">{t('profile.class')}: {aboutData.role}</div>
          <h1 class="text-3xl sm:text-5xl text-white uppercase leading-none mt-1 sm:mt-0">{aboutData.name}</h1>
        </div>
        <div class="bg-black border border-[var(--color-accent)] text-[var(--color-accent)] px-2 py-1 text-xs sm:text-sm whitespace-nowrap">
          {t('profile.status')}: {aboutData.status}
        </div>
      </div>
      <p class="text-gray-300 text-base sm:text-lg leading-tight mt-2 sm:mt-4">{aboutData.bio}</p>
    </div>
  </Panel>

  <div class="flex flex-col md:flex-row gap-2 sm:gap-4 flex-1 min-h-0 pb-2 sm:pb-0">
    <Panel className="p-3 sm:p-4 flex-1 flex flex-col">
      <h2 class="text-xl sm:text-2xl text-white mb-3 sm:mb-4 border-l-4 border-[var(--color-panel-border)] pl-2">{t('profile.parameters')}</h2>
      <div class="flex flex-col gap-3 sm:gap-4">
        {aboutData.stats.map(stat => (
          <StatBar name={stat.name} value={stat.value} colorClass={stat.class} />
        ))}
      </div>
    </Panel>
    
    <Panel className="p-3 sm:p-4 flex-1 flex flex-col">
      <h2 class="text-xl sm:text-2xl text-white mb-3 sm:mb-4 border-l-4 border-[var(--color-accent)] pl-2">{t('profile.software')}</h2>
      <div class="grid grid-cols-3 gap-2 mt-auto sm:mt-2">
        {aboutData.software.map(sw => (
          <div class="aspect-square bg-black border border-gray-600 flex flex-col items-center justify-center hover:border-white transition-colors group cursor-help relative p-1 sm:p-2 hover:bg-[var(--color-panel-bg)]">
            <Image src={sw.icon as any} alt={sw.name} width={48} height={48} class="w-8 h-8 sm:w-12 sm:h-12 pixelated mb-1 group-hover:scale-110 transition-transform" />
            <span class="text-[10px] sm:text-xs text-[var(--color-text-muted)] truncate w-full text-center group-hover:text-white transition-colors">{sw.name}</span>
          </div>
        ))}
        {Array.from({ length: 9 - aboutData.software.length }).map(_ => (
          <div class="aspect-square bg-black border border-gray-600 flex items-center justify-center text-gray-500 text-xs sm:text-base">{t('profile.empty')}</div>
        ))}
      </div>
    </Panel>
  </div>
</section>
