---
import Panel from './Panel.astro';
import StatBar from './StatBar.astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../i18n/utils';

const { lang } = Astro.props;
let profile;
try {
  const profileModule = await import(`../data/profile.${lang}.json`);
  profile = profileModule.default;
} catch (e) {
  // Fallback to empty structure
  profile = { 
    identity: { 
      name: "Artist", 
      class: "N/A", 
      level: 1, 
      status: "Offline", 
      bio: "..." 
    }, 
    stats: [], 
    software: [] 
  };
}
const t = useTranslations(lang);
---

<section id="view-profile" class="flex-1 flex flex-col gap-2 sm:gap-4 h-full overflow-y-auto pr-1 sm:pr-2">
  <Panel className="p-3 sm:p-4 flex flex-col sm:flex-row gap-4 sm:gap-6 items-center sm:items-start shrink-0 text-center sm:text-left">
    <div class="w-24 h-24 sm:w-48 sm:h-48 border-4 border-[var(--color-panel-border)] bg-black relative shrink-0 overflow-hidden">
      {profile.identity.avatar ? (
        <Image src={profile.identity.avatar} alt="Avatar" width={192} height={192} class="w-full h-full object-cover" loading="eager" />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-gray-700 bg-gray-900">
           <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
      )}
      {profile.identity.level !== undefined && (
        <div class="absolute bottom-0 w-full bg-[var(--color-panel-border)] text-black text-center font-bold text-xs sm:text-sm">
          Lv. {profile.identity.level}
        </div>
      )}
    </div>
    <div class="flex-1 w-full">
      <div class="flex flex-col sm:flex-row justify-between items-center sm:items-end border-b-2 border-gray-600 pb-2 mb-2 gap-2">
        <div>
          <div class="text-xs sm:text-sm text-[var(--color-panel-border)]">{t('profile.class')}: {profile.identity.class}</div>
          <h1 class="text-3xl sm:text-5xl text-white uppercase leading-none mt-1 sm:mt-0">{profile.identity.name}</h1>
        </div>
        <div class="bg-black border border-[var(--color-accent)] text-[var(--color-accent)] px-2 py-1 text-xs sm:text-sm whitespace-nowrap">
          {t('profile.status')}: {profile.identity.status}
        </div>
      </div>
      <p class="text-gray-300 text-base sm:text-lg leading-tight mt-2 sm:mt-4">{profile.identity.bio}</p>
    </div>
  </Panel>

  <div class="flex flex-col md:flex-row gap-2 sm:gap-4 flex-1 min-h-0 pb-2 sm:pb-0">
    <Panel className="p-3 sm:p-4 flex-1 flex flex-col">
      <h2 class="text-xl sm:text-2xl text-white mb-3 sm:mb-4 border-l-4 border-[var(--color-panel-border)] pl-2">{t('profile.parameters')}</h2>
      <div class="flex flex-col gap-3 sm:gap-4">
        {profile.stats?.map(stat => (
          <StatBar name={stat.name} value={stat.value} colorClass={stat.class} />
        ))}
      </div>
    </Panel>
    
    <Panel className="p-3 sm:p-4 flex-1 flex flex-col">
      <h2 class="text-xl sm:text-2xl text-white mb-3 sm:mb-4 border-l-4 border-[var(--color-accent)] pl-2">{t('profile.software')}</h2>
      <div class="grid grid-cols-3 gap-2 mt-auto sm:mt-2">
        {profile.software?.map(sw => (
          <div class="aspect-square bg-black border border-gray-600 flex flex-col items-center justify-center hover:border-white transition-colors group cursor-help relative p-1 sm:p-2 hover:bg-[var(--color-panel-bg)]">
            {sw.icon && !sw.icon.includes('undefined') ? (
               <Image src={sw.icon as any} alt={sw.name} width={48} height={48} class="w-8 h-8 sm:w-12 sm:h-12 pixelated mb-1 group-hover:scale-110 transition-transform" />
            ) : (
               <div class="w-8 h-8 sm:w-12 sm:h-12 flex items-center justify-center text-gray-700 opacity-40 mb-1">
                 <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-box"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
               </div>
            )}
            <span class="text-[10px] sm:text-xs text-[var(--color-text-muted)] truncate w-full text-center group-hover:text-white transition-colors">{sw.name}</span>
          </div>
        ))}
        {Array.from({ length: 9 - (profile.software?.length || 0) }).map(_ => (
          <div class="aspect-square bg-black border border-gray-600 flex items-center justify-center text-gray-500 text-xs sm:text-base">{t('profile.empty')}</div>
        ))}
      </div>
    </Panel>
  </div>
</section>
