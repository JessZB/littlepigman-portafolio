---
interface Props {
  title: string;
  lang?: string;
}

const { title, lang = 'es' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <title>{title} - Transer OS Portfolio</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com" is:inline></script>
    <!-- Fuente Pixelada -->
    <link
      href="https://fonts.googleapis.com/css2?family=VT323&display=swap"
      rel="stylesheet"
    />
    <!-- Three.js para el visor 3D -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js" is:inline></script>

    <style is:global>
      :root {
        /* Paleta del Artista (Purple Theme) */
        --color-bg-deep: #09000c;
        --color-dark-purple: #1c0217;
        --color-panel-bg: #311c48;

        --color-highlight: #4c3f91;
        --color-panel-border-glow: #9145b6;
        --color-panel-border: #b958a5;

        --color-danger: #ff5677;
        --color-accent: rgb(255, 234, 0);

        --color-text-main: #ffffff;
        --color-text-muted: #e0b0d5;
      }

      /* Estilos Globales y Reset Pixel Art */
      body {
        margin: 0;
        background-color: var(--color-bg-deep);
        background-image:
          radial-gradient(
            circle at 50% 50%,
            var(--color-dark-purple) 0%,
            var(--color-bg-deep) 100%
          ),
          linear-gradient(rgba(185, 88, 165, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(185, 88, 165, 0.05) 1px, transparent 1px);
        background-size:
          100% 100%,
          32px 32px,
          32px 32px;
        font-family: 'VT323', monospace;
        color: var(--color-text-main);
        overflow: hidden;
        image-rendering: pixelated;
        font-smooth: never;
        -webkit-font-smoothing: none;
      }

      .scanlines {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0),
          rgba(255, 255, 255, 0) 50%,
          rgba(0, 0, 0, 0.2) 50%,
          rgba(0, 0, 0, 0.2)
        );
        background-size: 100% 4px;
        pointer-events: none;
        z-index: 200; /* Siempre arriba de la UI */
      }

      .cyber-panel {
        background-color: var(--color-panel-bg);
        border: 2px solid var(--color-panel-border);
        box-shadow:
          inset 2px 2px 0px rgba(255, 255, 255, 0.2),
          inset -2px -2px 0px rgba(0, 0, 0, 0.6),
          0 4px 10px rgba(0, 0, 0, 0.5);
        position: relative;
      }

      .cyber-panel::before {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        width: 8px;
        height: 8px;
        background-color: var(--color-accent);
      }

      .nav-btn {
        background-color: var(--color-dark-purple);
        border: 2px solid var(--color-highlight);
        color: var(--color-text-muted);
        transition: all 0.1s steps(2);
        box-shadow: inset -2px -2px 0px rgba(0, 0, 0, 0.5);
        cursor: pointer;
        text-transform: uppercase;
      }

      .nav-btn:hover {
        background-color: var(--color-panel-border-glow);
        color: #fff;
      }

      .nav-btn.active {
        background-color: var(--color-panel-bg);
        border-color: var(--color-panel-border);
        color: #fff;
        box-shadow: inset 2px 2px 0px rgba(255, 255, 255, 0.3);
        transform: translateX(0px);
      }
      @media (min-width: 768px) {
        .nav-btn.active {
          transform: translateX(5px);
        }
      }

      /* Barras de estadísticas */
      .stat-bar-container {
        background-color: #000;
        border: 2px solid #333;
        height: 16px;
        width: 100%;
        position: relative;
      }
      .stat-bar-fill {
        height: 100%;
        background: linear-gradient(
          to bottom,
          #d279c1 0%,
          var(--color-panel-border) 50%,
          #7a2b69 100%
        );
        box-shadow: inset -2px 0px 0px rgba(0, 0, 0, 0.3);
        transition: width 0.5s ease-out;
      }
      .stat-bar-fill.exp {
        background: linear-gradient(
          to bottom,
          #ffffaa 0%,
          var(--color-accent) 50%,
          #aa8800 100%
        );
      }
      .stat-bar-fill.ui {
        background: linear-gradient(
          to bottom,
          #d699ef 0%,
          var(--color-panel-border-glow) 50%,
          #5d207a 100%
        );
      }

      /* Elementos de Galería y Proyectos */
      .gallery-item,
      .project-card {
        background-color: #000;
        border: 2px solid var(--color-text-muted);
        cursor: pointer;
        transition: all 0.1s steps(2);
        position: relative;
        overflow: hidden;
      }
      .gallery-item {
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .project-card {
        aspect-ratio: 16/9;
        display: flex;
        flex-direction: column;
      }

      .gallery-item:hover,
      .project-card:hover {
        border-color: var(--color-panel-border);
        transform: scale(1.02);
        z-index: 10;
        box-shadow: 0 0 15px rgba(185, 88, 165, 0.5);
      }

      .gallery-item img,
      .project-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        image-rendering: pixelated;
      }
      
      /* Esta regla oculta las scanlines SOLO para las imágenes en las que pases el mouse */
      .project-card:hover ~ .scanlines,
      #lightbox:not(.hidden) ~ .scanlines {
        display: none;
      }
      .project-card img {
        flex: 1;
        min-height: 0;
      }

      .gallery-badge {
        position: absolute;
        bottom: 0;
        right: 0;
        background: rgba(0, 0, 0, 0.8);
        color: var(--color-panel-border);
        font-size: 0.8rem;
        padding: 2px 4px;
        border-top: 1px solid var(--color-panel-border);
        border-left: 1px solid var(--color-panel-border);
      }

      .project-title-bar {
        background: var(--color-dark-purple);
        border-top: 2px solid var(--color-panel-border);
        padding: 4px 8px;
        font-size: 1rem;
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      @media (min-width: 640px) {
        .project-title-bar {
          font-size: 1.2rem;
        }
      }

      /* Utilidades */
      .view-hidden {
        display: none !important;
      }
      #lightbox {
        backdrop-filter: blur(4px);
      }
      .pixelated {
        image-rendering: pixelated;
      }

      /* Ocultar barra de scroll en navegación horizontal móvil */
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      /* Visor 3D y Assets */
      .holo-viewer {
        width: 100%;
        min-height: 200px;
        background: radial-gradient(circle at 50% 50%, #1c0217 0%, #000 100%);
        border: 2px solid var(--color-highlight);
        position: relative;
        cursor: grab;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      @media (min-width: 768px) {
        .holo-viewer {
          min-height: 250px;
        }
      }

      .holo-viewer:active {
        cursor: grabbing;
      }
      .holo-viewer::after {
        content: 'SIMULACIÓN_3D_ACTIVA';
        position: absolute;
        top: 4px;
        left: 4px;
        color: var(--color-highlight);
        font-size: 0.8rem;
        pointer-events: none;
      }

      /* Scrollbar general */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      @media (min-width: 768px) {
        ::-webkit-scrollbar {
          width: 12px;
          height: 12px;
        }
      }
      ::-webkit-scrollbar-track {
        background: #000;
        border-left: 1px solid var(--color-panel-border);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--color-panel-bg);
        border: 1px solid var(--color-panel-border);
      }

      /* Animaciones Lightbox */
      @keyframes zoomIn {
        from {
          opacity: 0;
          transform: scale(0.9);
        }
        to {
          opacity: 1;
          transform: scale(1);
        }
      }

      .animate-zoom-in {
        animation: zoomIn 0.2s steps(4) forwards;
      }

      /* Refinar visibilidad: Cuando el Lightbox está activo, ocultamos las scanlines */
      body:has(#lightbox:not(.hidden)) .scanlines {
        opacity: 0;
      }
    </style>
  </head>
  <body class="h-[100dvh] w-screen flex items-center justify-center text-lg sm:text-xl lg:text-2xl overflow-hidden">
    <div class="scanlines"></div>
    <div class="w-full h-full sm:max-w-6xl sm:max-h-[900px] flex flex-col md:flex-row sm:p-4 gap-2 sm:gap-4 relative">
        <slot />
    </div>
  </body>
</html>
