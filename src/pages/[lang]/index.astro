---
import TranserOS from '../../layouts/TranserOS.astro';
import Sidebar from '../../components/Sidebar.astro';
import ViewProfile from '../../components/ViewProfile.astro';
import ViewDatabase from '../../components/ViewDatabase.astro';
import ViewComms from '../../components/ViewComms.astro';

import { ui } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}
const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof ui);

// Importamos dinamicamente usando la API de Vite unwrap a .default
const worksDataModule = await import(`../../data/works.${lang}.json`);
const worksData = worksDataModule.default;
---

<TranserOS title="Transer OS">
  
  <!-- Language Toggle UI -->
  <div class="absolute top-2 right-2 sm:top-4 sm:right-4 z-[210] flex gap-2 font-['VT323']">
    <a href="/es/" class={`text-sm sm:text-lg border-2 px-1 sm:px-2 hover:bg-[var(--color-accent)] hover:text-black transition-colors ${lang === 'es' ? 'bg-[var(--color-accent)] text-black border-[var(--color-accent)]' : 'bg-black text-[var(--color-text-muted)] border-gray-600'}`}>ES</a>
    <a href="/en/" class={`text-sm sm:text-lg border-2 px-1 sm:px-2 hover:bg-[var(--color-accent)] hover:text-black transition-colors ${lang === 'en' ? 'bg-[var(--color-accent)] text-black border-[var(--color-accent)]' : 'bg-black text-[var(--color-text-muted)] border-gray-600'}`}>EN</a>
  </div>

  <Sidebar lang={lang} />
  <main class="flex-1 flex flex-col min-h-0 relative z-10 gap-2 sm:gap-4 px-2 pb-2 sm:px-0 sm:pb-0">
    <ViewProfile lang={lang} />
    <ViewDatabase lang={lang} worksData={worksData} />
    <ViewComms lang={lang} />
  </main>

  <!-- Modal Lightbox (Global) -->
  <div id="lightbox" class="fixed inset-0 bg-black/95 z-[100] hidden flex-col items-center justify-center p-2 sm:p-4 cursor-zoom-out" onclick="closeLightboxOnBackdrop(event)">
    <div id="lightbox-content" class="w-full max-w-4xl max-h-[90vh] cyber-panel p-2 flex flex-col relative cursor-default z-[101]">
      <button onclick="closeLightbox()" class="absolute -top-3 -right-3 sm:-top-4 sm:-right-4 bg-[var(--color-danger)] border-2 border-white text-white w-8 h-8 sm:w-10 sm:h-10 flex items-center justify-center hover:scale-110 z-10 cursor-pointer text-lg">
        X
      </button>
      <img id="lightbox-img" src="" alt="Arte" class="w-full h-[50vh] sm:h-[70vh] object-contain bg-black border-2 border-[var(--color-panel-border)] pixelated" loading="eager" />
      <div id="lightbox-title" class="text-center text-[var(--color-panel-border)] mt-2 text-xl sm:text-2xl uppercase truncate px-4"></div>
    </div>
  </div>
</TranserOS>

<!-- Inyectar data requerida por el JS Cliente para los modales de Project -->
<script is:inline define:vars={{ 
  worksData, 
  textRol: t('proj.role'), 
  textLog: t('proj.log'), 
  textAssets: t('proj.assets') 
}}>
  window.portfolioDB = { projects: worksData };
  window.portfolioUI = { role: textRol, log: textLog, assets: textAssets };
</script>

<script is:inline>
  // Reloj
  function updateClock() {
    const timeStr = new Date().toLocaleTimeString('es-ES', { hour12: false });
    document.querySelectorAll('.clock-display').forEach((el) => (el.textContent = timeStr));
  }
  setInterval(updateClock, 1000);
  updateClock();

  // Switch View
  function switchView(viewId, btnElement) {
    document.querySelectorAll('main > section').forEach((el) => el.classList.add('view-hidden'));
    document.getElementById(viewId).classList.remove('view-hidden');
    document.querySelectorAll('.nav-btn').forEach((btn) => btn.classList.remove('active'));
    btnElement.classList.add('active');

    if (viewId === 'view-database') closeProject();

    if (window.innerWidth < 768) {
      btnElement.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }

  // Lógica Database (Proyectos)
  let currentAnimationId = null;

  function openProject(projectId) {
    const project = window.portfolioDB.projects.find((p) => p.id === projectId);
    if (!project) return;
    document.getElementById('project-list-view').classList.add('view-hidden');
    const detailView = document.getElementById('project-detail-view');
    detailView.classList.remove('view-hidden');

    let contentHTML = `
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 items-start border-b-2 border-gray-600 pb-3 sm:pb-4">
          <img src="${project.thumbnail}" class="w-full sm:w-1/3 border-2 border-[var(--color-highlight)] pixelated" alt="Thumb">
          <div class="w-full">
              <h1 class="text-2xl sm:text-4xl text-white uppercase mb-1 sm:mb-2 text-shadow-glow">${project.title}</h1>
              <div class="text-[var(--color-accent)] mb-2 sm:mb-4 text-sm sm:text-base">${window.portfolioUI.role}: ${project.role}</div>
              <p class="text-gray-300 text-base sm:text-lg">${project.description}</p>
          </div>
      </div>
      <h2 class="text-xl sm:text-2xl text-white border-l-4 border-[var(--color-danger)] pl-2 mt-2 sm:mt-4 uppercase">${window.portfolioUI.log}</h2>
      <div class="flex flex-col gap-4 sm:gap-8">
    `;

    project.workDone.forEach((work, index) => {
      if (work.type === '3d-model') {
          contentHTML += `
            <div class="bg-black border border-[var(--color-panel-border)] p-3 sm:p-4 flex flex-col gap-3 sm:gap-4">
                <div>
                    <h3 class="text-xl sm:text-2xl text-[var(--color-panel-border-glow)] leading-tight">${work.title}</h3>
                    <p class="text-gray-400 text-sm sm:text-base mt-1">${work.description}</p>
                </div>
                <div class="flex flex-col lg:flex-row gap-3 sm:gap-4">
                    <div class="w-full lg:w-2/3 holo-viewer" id="canvas-container-${index}"></div>
                    <div class="w-full lg:w-1/3 flex flex-col gap-2">
                        <span class="text-[var(--color-accent)] text-xs sm:text-sm border-b border-gray-600 pb-1">${window.portfolioUI.assets}</span>
                        <div class="grid grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 gap-2">
                            ${work.textures.map(tex => `
                                <div class="flex flex-col cursor-pointer hover:border-[var(--color-panel-border)] border border-transparent transition-all" onclick="openLightbox('${tex.img}', '${tex.name}')">
                                    <img src="${tex.img}" class="w-full aspect-square object-cover pixelated border border-gray-700" alt="${tex.name}">
                                    <span class="text-[10px] sm:text-xs text-center text-gray-400 mt-1 truncate px-1">${tex.name}</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                </div>
            </div>`;
      } else if (work.type === 'asset-group') {
        contentHTML += `
          <div class="bg-black border border-[var(--color-highlight)] p-3 sm:p-4">
              <h3 class="text-xl sm:text-2xl text-[var(--color-text-muted)] mb-1 leading-tight">${work.groupTitle}</h3>
              ${work.description ? `<p class="text-gray-400 text-sm sm:text-base mb-3 sm:mb-4">${work.description}</p>` : ''}
              <div class="grid grid-cols-2 min-[480px]:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 sm:gap-4">
                  ${work.items.map(item => `
                      <div class="bg-[#111] border border-gray-700 p-2 cursor-pointer hover:border-[var(--color-accent)] transition-colors group flex flex-col" onclick="openLightbox('${item.img}', '${item.title}')">
                          <div class="aspect-square bg-[#000] mb-2 flex items-center justify-center overflow-hidden">
                              <img src="${item.img}" class="w-full h-full object-cover pixelated group-hover:scale-110 transition-transform" alt="${item.title}">
                          </div>
                          <div class="text-white text-sm sm:text-lg leading-tight truncate">${item.title}</div>
                          ${item.desc ? `<div class="text-[var(--color-panel-border)] text-xs sm:text-sm truncate mt-auto">${item.desc}</div>` : ''}
                      </div>
                  `).join('')}
              </div>
          </div>`;
      }
    });
    contentHTML += `</div>`;
    document.getElementById('project-content-area').innerHTML = contentHTML;

    setTimeout(() => {
      project.workDone.forEach((work, index) => {
        if (work.type === '3d-model') {
          initThreeJSHologram(`canvas-container-${index}`, work.modelPlaceholderColor);
        }
      });
      window.dispatchEvent(new Event('resize'));
    }, 50);
  }

  function closeProject() {
    document.getElementById('project-detail-view').classList.add('view-hidden');
    document.getElementById('project-list-view').classList.remove('view-hidden');
    document.getElementById('project-content-area').innerHTML = '';
    if (currentAnimationId) cancelAnimationFrame(currentAnimationId);
  }

  // Three JS init
  function initThreeJSHologram(containerId, hexColor) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, container.clientWidth / container.clientHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: false });
    renderer.setSize(container.clientWidth, container.clientHeight);
    container.appendChild(renderer.domElement);

    const geometry = new THREE.IcosahedronGeometry(1.5, 0);
    const material = new THREE.MeshBasicMaterial({ color: hexColor, wireframe: true, wireframeLinewidth: 2 });
    const mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);

    const coreMat = new THREE.MeshBasicMaterial({ color: 0x110011 });
    const core = new THREE.Mesh(new THREE.IcosahedronGeometry(1.4, 0), coreMat);
    scene.add(core);

    camera.position.z = 5;

    let isDragging = false;
    let previousPosition = { x: 0, y: 0 };

    container.addEventListener('mousedown', (e) => { isDragging = true; previousPosition = { x: e.offsetX, y: e.offsetY }; });
    window.addEventListener('mouseup', () => (isDragging = false));
    window.addEventListener('mousemove', (e) => {
      if (isDragging) {
        const deltaMove = { x: e.offsetX - previousPosition.x, y: e.offsetY - previousPosition.y };
        mesh.rotation.y += deltaMove.x * 0.01;
        mesh.rotation.x += deltaMove.y * 0.01;
        core.rotation.y += deltaMove.x * 0.01;
        core.rotation.x += deltaMove.y * 0.01;
      }
      previousPosition = { x: e.offsetX, y: e.offsetY };
    });

    container.addEventListener('touchstart', (e) => {
      isDragging = true;
      previousPosition = { x: e.touches[0].clientX, y: e.touches[0].clientY };
    }, { passive: true });
    window.addEventListener('touchend', () => (isDragging = false));
    window.addEventListener('touchmove', (e) => {
      if (isDragging) {
        const deltaMove = { x: e.touches[0].clientX - previousPosition.x, y: e.touches[0].clientY - previousPosition.y };
        mesh.rotation.y += deltaMove.x * 0.01;
        mesh.rotation.x += deltaMove.y * 0.01;
        core.rotation.y += deltaMove.x * 0.01;
        core.rotation.x += deltaMove.y * 0.01;
        previousPosition = { x: e.touches[0].clientX, y: e.touches[0].clientY };
      }
    }, { passive: true });

    function animate() {
      currentAnimationId = requestAnimationFrame(animate);
      if (!isDragging) {
        mesh.rotation.y += 0.005;
        mesh.rotation.x += 0.002;
        core.rotation.y += 0.005;
        core.rotation.x += 0.002;
      }
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
      if (container && container.clientWidth > 0) {
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
      }
    });
  }

  // Lightbox
  function openLightbox(imgSrc, title) {
    const lb = document.getElementById('lightbox');
    const content = document.getElementById('lightbox-content');
    document.getElementById('lightbox-img').src = imgSrc;
    document.getElementById('lightbox-title').textContent = title;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    content.classList.add('animate-zoom-in');
  }
  function closeLightbox() {
    const lb = document.getElementById('lightbox');
    const content = document.getElementById('lightbox-content');
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    content.classList.remove('animate-zoom-in');
  }
  function closeLightboxOnBackdrop(e) {
    if (e.target.id === 'lightbox') {
      closeLightbox();
    }
  }
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
