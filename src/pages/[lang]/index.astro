---
import TranserOS from '../../layouts/TranserOS.astro';
import Sidebar from '../../components/Sidebar.astro';
import ViewProfile from '../../components/ViewProfile.astro';
import ViewDatabase from '../../components/ViewDatabase.astro';
import ViewComms from '../../components/ViewComms.astro';

import { ui } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}
const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof ui);

// Importamos dinamicamente usando la API de Vite unwrap a .default
const worksDataModule = await import(`../../data/works.${lang}.json`);
const worksData = worksDataModule.default;
---

<TranserOS title="Transer OS" lang={lang}>
  
  <!-- Language Toggle UI -->
  <div class="absolute top-2 right-2 sm:top-4 sm:right-4 z-[210] flex gap-2 font-['VT323']">
    <a href="/es/" class={`text-sm sm:text-lg border-2 px-1 sm:px-2 hover:bg-[var(--color-accent)] hover:text-black transition-colors ${lang === 'es' ? 'bg-[var(--color-accent)] text-black border-[var(--color-accent)]' : 'bg-black text-[var(--color-text-muted)] border-gray-600'}`}>ES</a>
    <a href="/en/" class={`text-sm sm:text-lg border-2 px-1 sm:px-2 hover:bg-[var(--color-accent)] hover:text-black transition-colors ${lang === 'en' ? 'bg-[var(--color-accent)] text-black border-[var(--color-accent)]' : 'bg-black text-[var(--color-text-muted)] border-gray-600'}`}>EN</a>
  </div>

  <Sidebar lang={lang} />
  <main class="flex-1 flex flex-col min-h-0 relative z-10 gap-2 sm:gap-4 px-2 pb-2 sm:px-0 sm:pb-0">
    <ViewProfile lang={lang} />
    <ViewDatabase lang={lang} worksData={worksData} />
    <ViewComms lang={lang} />
  </main>

  <!-- Modal Lightbox (Global) -->
  <div id="lightbox" class="fixed inset-0 bg-black/95 z-[100] hidden flex-col items-center justify-center p-2 sm:p-4 cursor-zoom-out" onclick="closeLightboxOnBackdrop(event)">
    <div id="lightbox-content" class="w-full max-w-4xl max-h-[90vh] cyber-panel p-2 flex flex-col relative cursor-default z-[101]">
      <button onclick="closeLightbox()" class="absolute -top-3 -right-3 sm:-top-4 sm:-right-4 bg-[var(--color-danger)] border-2 border-white text-white w-8 h-8 sm:w-10 sm:h-10 flex items-center justify-center hover:scale-110 z-10 cursor-pointer text-lg">
        X
      </button>
      <img id="lightbox-img" src="" alt={lang === 'es' ? 'Arte' : 'Art'} class="w-full h-[50vh] sm:h-[70vh] object-contain bg-black border-2 border-[var(--color-panel-border)] pixelated" loading="eager" />
      <div id="lightbox-title" class="text-center text-[var(--color-panel-border)] mt-2 text-xl sm:text-2xl uppercase truncate px-4"></div>
    </div>
  </div>
</TranserOS>

<!-- Inyectar data requerida por el JS Cliente para los modales de Project -->
<script is:inline define:vars={{ 
  worksData, 
  lang,
  textRol: t('proj.role'), 
  textLog: t('proj.log'), 
  textAssets: t('proj.assets') 
}}>
  window.portfolioDB = { projects: worksData };
  window.portfolioUI = { role: textRol, log: textLog, assets: textAssets, lang };
</script>

<script is:inline>
  // Reloj
  function updateClock() {
    const locale = window.portfolioUI.lang === 'es' ? 'es-ES' : 'en-US';
    const timeStr = new Date().toLocaleTimeString(locale, { hour12: false });
    document.querySelectorAll('.clock-display').forEach((el) => (el.textContent = timeStr));
  }
  setInterval(updateClock, 1000);
  updateClock();

  // Switch View
  function switchView(viewId, btnElement) {
    document.querySelectorAll('main > section').forEach((el) => el.classList.add('view-hidden'));
    document.getElementById(viewId).classList.remove('view-hidden');
    document.querySelectorAll('.nav-btn').forEach((btn) => btn.classList.remove('active'));
    btnElement.classList.add('active');

    if (viewId === 'view-database') closeProject();

    if (window.innerWidth < 768) {
      btnElement.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }

  // Lógica Database (Proyectos)
  let currentAnimationId = null;

  function openProject(projectId) {
    const project = window.portfolioDB.projects.find((p) => p.id === projectId);
    if (!project) return;
    document.getElementById('project-list-view').classList.add('view-hidden');
    const detailView = document.getElementById('project-detail-view');
    detailView.classList.remove('view-hidden');

    let contentHTML = `
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 items-start border-b-2 border-gray-600 pb-3 sm:pb-4">
          ${project.thumbnail ? `
            <img src="${project.thumbnail}" class="w-full sm:w-1/3 border-2 border-[var(--color-highlight)] pixelated" alt="Thumb">
          ` : `
            <div class="w-full sm:w-1/3 aspect-video bg-gray-900 border-2 border-gray-700 flex items-center justify-center text-gray-700">
               <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            </div>
          `}
          <div class="w-full">
              <h1 class="text-2xl sm:text-4xl text-white uppercase mb-1 sm:mb-2 text-shadow-glow">${project.title}</h1>
              <div class="text-[var(--color-accent)] mb-2 sm:mb-4 text-sm sm:text-base">${window.portfolioUI.role}: ${project.role}</div>
              <p class="text-gray-300 text-base sm:text-lg">${project.description}</p>
          </div>
      </div>
      <h2 class="text-xl sm:text-2xl text-white border-l-4 border-[var(--color-danger)] pl-2 mt-2 sm:mt-4 uppercase">${window.portfolioUI.log}</h2>
      <div class="flex flex-col gap-4 sm:gap-8">
    `;

    project.workDone.forEach((work, index) => {
      if (work.type === '3d-model') {
          contentHTML += `
            <div class="bg-black border border-[var(--color-panel-border)] p-3 sm:p-4 flex flex-col gap-3 sm:gap-4">
                <div>
                    <h3 class="text-xl sm:text-2xl text-[var(--color-panel-border-glow)] leading-tight">${work.title}</h3>
                    <p class="text-gray-400 text-sm sm:text-base mt-1">${work.description}</p>
                </div>
                <div class="flex flex-col lg:flex-row gap-3 sm:gap-4">
                    <div class="relative w-full lg:w-2/3">
                        <div class="w-full h-full holo-viewer" id="canvas-container-${index}"></div>
                        <div class="absolute bottom-2 right-2 flex gap-2 z-10">
                            <button onclick="window.toggle3DRotation('canvas-container-${index}')" class="bg-[var(--color-dark-purple)] border border-[var(--color-highlight)] text-white px-3 py-1 text-xs hover:bg-[var(--color-panel-border)] shadow-md">↺</button>
                            <button onclick="window.zoom3DModel('canvas-container-${index}', -1)" class="bg-[var(--color-dark-purple)] border border-[var(--color-highlight)] text-white px-3 py-1 text-xs hover:bg-[var(--color-panel-border)] shadow-md">-</button>
                            <button onclick="window.zoom3DModel('canvas-container-${index}', 1)" class="bg-[var(--color-dark-purple)] border border-[var(--color-highlight)] text-white px-3 py-1 text-xs hover:bg-[var(--color-panel-border)] shadow-md">+</button>
                        </div>
                    </div>
                    <div class="w-full lg:w-1/3 flex flex-col gap-2">
                        <span class="text-[var(--color-accent)] text-xs sm:text-sm border-b border-gray-600 pb-1">${window.portfolioUI.assets}</span>
                        <div class="grid grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 gap-2">
                            ${work.textures.map(tex => `
                                <div class="flex flex-col cursor-pointer hover:border-[var(--color-panel-border)] border border-transparent transition-all" onclick="openLightbox('${tex.img}', '${tex.name}'); window.changeHologramTexture && window.changeHologramTexture('canvas-container-${index}', '${tex.img}')">
                                    ${tex.img ? ` <img src="${tex.img}" class="w-full aspect-square object-cover pixelated border border-gray-700" alt="${tex.name}">` : `<div class="w-full aspect-square bg-gray-900 border border-gray-700 flex items-center justify-center text-gray-700 text-[10px]">NO IMG</div>`}
                                    <span class="text-[10px] sm:text-xs text-center text-gray-400 mt-1 truncate px-1">${tex.name}</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                </div>
            </div>`;
      } else if (work.type === 'gltf-model') {
          contentHTML += `
            <div class="bg-black border border-[var(--color-panel-border)] p-3 sm:p-4 flex flex-col gap-3 sm:gap-4">
                <div>
                    <h3 class="text-xl sm:text-2xl text-[var(--color-panel-border-glow)] leading-tight">${work.title}</h3>
                    <p class="text-gray-400 text-sm sm:text-base mt-1">${work.description}</p>
                </div>
                <div class="relative w-full aspect-video border-2 border-[var(--color-accent)]">
                    <div class="w-full h-full holo-viewer" id="canvas-container-${index}"></div>
                    <div class="absolute bottom-2 right-2 flex gap-2 z-10">
                        <button onclick="window.toggle3DRotation('canvas-container-${index}')" class="bg-[var(--color-dark-purple)] border border-[var(--color-highlight)] text-white px-3 py-1 text-sm hover:bg-[var(--color-panel-border)] shadow-md">↺</button>
                        <button onclick="window.zoom3DModel('canvas-container-${index}', -1)" class="bg-[var(--color-dark-purple)] border border-[var(--color-highlight)] text-white px-3 py-1 text-sm hover:bg-[var(--color-panel-border)] shadow-md">-</button>
                        <button onclick="window.zoom3DModel('canvas-container-${index}', 1)" class="bg-[var(--color-dark-purple)] border border-[var(--color-highlight)] text-white px-3 py-1 text-sm hover:bg-[var(--color-panel-border)] shadow-md">+</button>
                    </div>
                </div>
            </div>`;
      } else if (work.type === 'asset-group') {
        contentHTML += `
          <div class="bg-black border border-[var(--color-highlight)] p-3 sm:p-4">
              <h3 class="text-xl sm:text-2xl text-[var(--color-text-muted)] mb-1 leading-tight">${work.groupTitle}</h3>
              ${work.description ? `<p class="text-gray-400 text-sm sm:text-base mb-3 sm:mb-4">${work.description}</p>` : ''}
              <div class="grid grid-cols-2 min-[480px]:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 sm:gap-4">
                  ${work.items.map(item => `
                      <div class="bg-[#111] border border-gray-700 p-2 cursor-pointer hover:border-[var(--color-accent)] transition-colors group flex flex-col" onclick="${item.img ? `openLightbox('${item.img}', '${item.title}')` : ''}">
                          <div class="aspect-square bg-[#000] mb-2 flex items-center justify-center overflow-hidden">
                              ${item.img ? `<img src="${item.img}" class="w-full h-full object-cover pixelated group-hover:scale-110 transition-transform" alt="${item.title}">` : `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-gray-800"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>`}
                          </div>
                          <div class="text-white text-sm sm:text-lg leading-tight truncate">${item.title}</div>
                          ${item.desc ? `<div class="text-[var(--color-panel-border)] text-xs sm:text-sm truncate mt-auto">${item.desc}</div>` : ''}
                      </div>
                  `).join('')}
              </div>
          </div>`;
      }
    });
    contentHTML += `</div>`;
    document.getElementById('project-content-area').innerHTML = contentHTML;

    setTimeout(() => {
      project.workDone.forEach((work, index) => {
        if (work.type === '3d-model') {
          const firstTex = work.textures && work.textures.length > 0 ? work.textures[0].img : null;
          initThreeJSHologram(`canvas-container-${index}`, work.modelPlaceholderColor || 0xff00ff, firstTex);
        } else if (work.type === 'gltf-model') {
          initThreeJSGLTF(`canvas-container-${index}`, work.modelUrl);
        }
      });
      window.dispatchEvent(new Event('resize'));
    }, 50);
  }

  function closeProject() {
    document.getElementById('project-detail-view').classList.add('view-hidden');
    document.getElementById('project-list-view').classList.remove('view-hidden');
    document.getElementById('project-content-area').innerHTML = '';
    if (currentAnimationId) cancelAnimationFrame(currentAnimationId);
  }

  window.threeJSModels = window.threeJSModels || {};
  window.threeJSControls = window.threeJSControls || {};

  window.toggle3DRotation = function(id) {
    if(window.threeJSControls[id]) {
      window.threeJSControls[id].rotate = !window.threeJSControls[id].rotate;
    }
  };

  window.zoom3DModel = function(id, dir) {
    if(window.threeJSControls[id]) {
        const cam = window.threeJSControls[id].camera;
        cam.position.z -= dir * 1.5;
        if(cam.position.z < 2) cam.position.z = 2;
        if(cam.position.z > 15) cam.position.z = 15;
    }
  };

  // Three JS init
  function initThreeJSHologram(containerId, hexColor, textureUrl) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, container.clientWidth / container.clientHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: false });
    renderer.setSize(container.clientWidth, container.clientHeight);
    container.appendChild(renderer.domElement);

    let mesh, core;

    if (textureUrl) {
        const loader = new THREE.TextureLoader();
        const texture = loader.load(textureUrl);
        texture.magFilter = THREE.NearestFilter;
        texture.minFilter = THREE.NearestFilter;
        const geometry = new THREE.BoxGeometry(2, 2, 2);
        const material = new THREE.MeshBasicMaterial({ map: texture });
        mesh = new THREE.Mesh(geometry, material);
        scene.add(mesh);
    } else {
        const geometry = new THREE.IcosahedronGeometry(1.5, 0);
        const material = new THREE.MeshBasicMaterial({ color: hexColor, wireframe: true, wireframeLinewidth: 2 });
        mesh = new THREE.Mesh(geometry, material);
        scene.add(mesh);

        const coreMat = new THREE.MeshBasicMaterial({ color: 0x110011 });
        core = new THREE.Mesh(new THREE.IcosahedronGeometry(1.4, 0), coreMat);
        scene.add(core);
    }

    camera.position.z = 5;

    window.threeJSModels[containerId] = mesh || core;
    window.threeJSControls[containerId] = { rotate: true, camera: camera };

    let isDragging = false;
    let previousPosition = { x: 0, y: 0 };

    container.addEventListener('mousedown', (e) => { isDragging = true; previousPosition = { x: e.offsetX, y: e.offsetY }; });
    window.addEventListener('mouseup', () => (isDragging = false));
    window.addEventListener('mousemove', (e) => {
      if (isDragging) {
        const deltaMove = { x: e.offsetX - previousPosition.x, y: e.offsetY - previousPosition.y };
        mesh.rotation.y += deltaMove.x * 0.01;
        mesh.rotation.x += deltaMove.y * 0.01;
        if (core) {
            core.rotation.y += deltaMove.x * 0.01;
            core.rotation.x += deltaMove.y * 0.01;
        }
      }
      previousPosition = { x: e.offsetX, y: e.offsetY };
    });

    container.addEventListener('touchstart', (e) => {
      isDragging = true;
      previousPosition = { x: e.touches[0].clientX, y: e.touches[0].clientY };
    }, { passive: true });
    window.addEventListener('touchend', () => (isDragging = false));
    window.addEventListener('touchmove', (e) => {
      if (isDragging) {
        const deltaMove = { x: e.touches[0].clientX - previousPosition.x, y: e.touches[0].clientY - previousPosition.y };
        mesh.rotation.y += deltaMove.x * 0.01;
        mesh.rotation.x += deltaMove.y * 0.01;
        if (core) {
            core.rotation.y += deltaMove.x * 0.01;
            core.rotation.x += deltaMove.y * 0.01;
        }
        previousPosition = { x: e.touches[0].clientX, y: e.touches[0].clientY };
      }
    }, { passive: true });

    container.addEventListener('wheel', (e) => {
      e.preventDefault();
      camera.position.z += e.deltaY * 0.005;
      if (camera.position.z < 2) camera.position.z = 2;
      if (camera.position.z > 12) camera.position.z = 12;
    }, { passive: false });

    function animate() {
      currentAnimationId = requestAnimationFrame(animate);
      if (!isDragging && window.threeJSControls[containerId].rotate) {
        if(mesh) {
            mesh.rotation.y += 0.005;
            mesh.rotation.x += 0.002;
        }
        if (core) {
            core.rotation.y += 0.005;
            core.rotation.x += 0.002;
        }
      }
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
      if (container && container.clientWidth > 0) {
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
      }
    });
  }

  window.changeHologramTexture = function(containerId, imgSrc) {
    if (window.threeJSModels && window.threeJSModels[containerId]) {
        const mesh = window.threeJSModels[containerId];
        const loader = new THREE.TextureLoader();
        const texture = loader.load(imgSrc);
        texture.magFilter = THREE.NearestFilter;
        texture.minFilter = THREE.NearestFilter;
        
        if (mesh.material.map) {
           mesh.material.map.dispose();
        } else {
            mesh.material.wireframe = false;
        }
        mesh.material.map = texture;
        mesh.material.needsUpdate = true;
    }
  };

  function initThreeJSGLTF(containerId, modelUrl) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const scene = new THREE.Scene();
    
    // Add lighting for the model
    const ambientLight = new THREE.AmbientLight(0xffffff, 1.5);
    scene.add(ambientLight);
    
    const directionalLight = new THREE.DirectionalLight(0xffffff, 2);
    directionalLight.position.set(5, 10, 5);
    scene.add(directionalLight);

    const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: false });
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.pixelRatio = window.devicePixelRatio; // essential for pixel art sharpness on retina
    container.appendChild(renderer.domElement);

    let modelGroup = new THREE.Group();
    scene.add(modelGroup);

    // Ensure THREE.GLTFLoader is available (added via CDN globally)
    if (typeof THREE.GLTFLoader !== 'undefined') {
        const loader = new THREE.GLTFLoader();
        loader.load(modelUrl, function (gltf) {
            const model = gltf.scene;
            
            // Adjust center and scale so it fits perfectly on screen
            const box = new THREE.Box3().setFromObject(model);
            const center = box.getCenter(new THREE.Vector3());
            const size = box.getSize(new THREE.Vector3());

            const maxDim = Math.max(size.x, size.y, size.z);
            let scale = 1;
            if (maxDim > 0) {
                scale = 3 / maxDim; // Fit inside a 3 unit box
            }
            model.scale.set(scale, scale, scale);
            
            // Center the model's pivot
            model.position.sub(center.multiplyScalar(scale));
            
            // Apply crisp pixel-art filtering recursively
            model.traverse((child) => {
                if (child.isMesh && child.material && child.material.map) {
                    child.material.map.magFilter = THREE.NearestFilter;
                    child.material.map.minFilter = THREE.NearestFilter;
                    child.material.map.generateMipmaps = false;
                }
            });

            modelGroup.add(model);
            
        }, undefined, function (error) {
            console.error('Error loading GLTF model:', error);
            container.innerHTML = '<span class="text-red-500">Error loading 3D Model (' + error.message + ')</span>';
        });
    } else {
        console.error("GLTFLoader missing!");
    }

    camera.position.z = 6;
    
    window.threeJSModels[containerId] = modelGroup;
    window.threeJSControls[containerId] = { rotate: true, camera: camera };

    let isDragging = false;
    let previousPosition = { x: 0, y: 0 };

    container.addEventListener('mousedown', (e) => { isDragging = true; previousPosition = { x: e.offsetX, y: e.offsetY }; });
    window.addEventListener('mouseup', () => (isDragging = false));
    window.addEventListener('mousemove', (e) => {
      if (isDragging) {
        const deltaMove = { x: e.offsetX - previousPosition.x, y: e.offsetY - previousPosition.y };
        modelGroup.rotation.y += deltaMove.x * 0.01;
        modelGroup.rotation.x += deltaMove.y * 0.01;
      }
      previousPosition = { x: e.offsetX, y: e.offsetY };
    });

    container.addEventListener('touchstart', (e) => {
      isDragging = true;
      previousPosition = { x: e.touches[0].clientX, y: e.touches[0].clientY };
    }, { passive: true });
    window.addEventListener('touchend', () => (isDragging = false));
    window.addEventListener('touchmove', (e) => {
      if (isDragging) {
        const deltaMove = { x: e.touches[0].clientX - previousPosition.x, y: e.touches[0].clientY - previousPosition.y };
        modelGroup.rotation.y += deltaMove.x * 0.01;
        modelGroup.rotation.x += deltaMove.y * 0.01;
        previousPosition = { x: e.touches[0].clientX, y: e.touches[0].clientY };
      }
    }, { passive: true });

    container.addEventListener('wheel', (e) => {
      e.preventDefault();
      camera.position.z += e.deltaY * 0.005;
      if (camera.position.z < 2) camera.position.z = 2;
      if (camera.position.z > 15) camera.position.z = 15;
    }, { passive: false });

    function animate() {
      currentAnimationId = requestAnimationFrame(animate);
      if (!isDragging && window.threeJSControls[containerId].rotate) {
        modelGroup.rotation.y += 0.01;
      }
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
      if (container && container.clientWidth > 0) {
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
      }
    });
  }

  // Lightbox
  function openLightbox(imgSrc, title) {
    const lb = document.getElementById('lightbox');
    const content = document.getElementById('lightbox-content');
    document.getElementById('lightbox-img').src = imgSrc;
    document.getElementById('lightbox-title').textContent = title;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    content.classList.add('animate-zoom-in');
  }
  function closeLightbox() {
    const lb = document.getElementById('lightbox');
    const content = document.getElementById('lightbox-content');
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    content.classList.remove('animate-zoom-in');
  }
  function closeLightboxOnBackdrop(e) {
    if (e.target.id === 'lightbox') {
      closeLightbox();
    }
  }
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
